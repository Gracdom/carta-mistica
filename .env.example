# ── Supabase (frontend) ──────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Admin ────────────────────────────────────────────────────────────────────
VITE_ADMIN_EMAIL=admin@carta.com

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-tu-clave-aqui

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=TU_STRIPE_SECRET_KEY_AQUI
STRIPE_WEBHOOK_SECRET=TU_STRIPE_WEBHOOK_SECRET_AQUI
PRECIO_LECTURA_CENTAVOS=1500
MONEDA=usd

# ── Resend (envío de emails) ─────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Carta Mística <noreply@cartamistica.com>

# ── Supabase (server-side — Netlify Functions) ───────────────────────────────
# Usar service role key (NO la anon key) para bypasear RLS desde el webhook
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
